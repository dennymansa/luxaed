{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": true,
  "cleanUrls": true,
  "redirects": [
    { "source": "/kontakt", "destination": "/", "permanent": true },
    { "source": "/kontakt/", "destination": "/", "permanent": true },
    { "source": "/ru/kontakty", "destination": "/ru/", "permanent": true },
    { "source": "/ru/kontakty/", "destination": "/ru/", "permanent": true },
    { "source": "/en/contact", "destination": "/en/", "permanent": true },
    { "source": "/en/contact/", "destination": "/en/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/img/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
